PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/airbnb-clone
JWT_SECRET=your-super-secret-jwt-key-change-in-production
CLIENT_URL=http://localhost:5173

# Optional — leave empty to use local uploads folder
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Gmail SMTP Setup (Configure these to send real emails via Gmail)
EMAIL=
EMAIL_PASSWORD=

# Alternative Generic SMTP Setup
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM="Nestfinder" <noreply@airbnb-clone.com>

# Twilio SMS Setup (Configure these to send real OTPs to mobile numbers)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
